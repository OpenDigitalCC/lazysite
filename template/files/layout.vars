# tt_site_var - site-wide Template Toolkit variables
# Available in layout.tt and all pages as [% variable_name %]
#
# Syntax:
#   key: value              literal string value
#   key: url:https://...    fetch value from URL (cached with page TTL)
#
# Examples:
#   site_name: My Site
#   version: url:https://raw.githubusercontent.com/example/repo/main/VERSION
