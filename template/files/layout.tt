<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>[% page_title %]</title>
</head>
<body>

<header>
    <h1>[% page_title %]</h1>
[% IF page_subtitle %]
    <p>[% page_subtitle %]</p>
[% END %]
</header>

<main>
[% content %]
</main>

<footer>
    <p>Site footer</p>
</footer>

</body>
</html>
