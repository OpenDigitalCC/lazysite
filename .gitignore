# Test site
test-site/

# Runtime files in starter - not tracked, differ per installation
starter/lazysite/lazysite.conf
starter/lazysite/nav.conf
starter/lazysite/auth/users
starter/lazysite/auth/groups
starter/lazysite/auth/.secret
starter/lazysite/forms/.secret
starter/lazysite/forms/.rate-limit.db
starter/lazysite/forms/.smtp-password
starter/lazysite/forms/contact.conf
starter/lazysite/forms/handlers.conf
starter/lazysite/forms/smtp.conf
starter/lazysite/logs/
starter/lazysite/manager/locks/
starter/lazysite/cache/

# Manager CSS served copy (source is starter/lazysite/manager/assets/)
starter/manager/assets/manager.css

# Compiled HTML cache files
starter/**/*.html

# Deployment-only rsync helper (lives at /srv/projects/lazysite/)
rsync-from-source.sh

# OS files
.DS_Store

# Release artefacts. dist/ root is ignored by default;
# tools/release.sh drops new tarballs + .sha256 there on every
# release cut. dist/config/ is explicitly tracked - it holds
# build inputs (classification.json, sbom-deps.json) alongside
# the build outputs.
dist/*
!dist/config/
!dist/config/*

# SM065: release-generated, per-release artefacts. Under SM063
# these live in the tarball only (tools/release.sh generates
# them fresh into staging). Tracked copies would drift behind
# the last-released tarball and mislead operators.
sbom.json
release-manifest.json

# SM063: CC writes .commit-message.md per session; tools/commit.sh
# reads it as the commit body and deletes it on success. The file
# is session-ephemeral workflow state, never committed.
.commit-message.md

# SM063: audit/research artefacts produced by exploratory sessions.
# Never committed; documented in docs/development.md if they inform
# subsequent SMs.
.release-audit.md
