# Test site
test-site/

# Runtime files in starter - not tracked, differ per installation
starter/lazysite/lazysite.conf
starter/lazysite/nav.conf
starter/lazysite/auth/users
starter/lazysite/auth/groups
starter/lazysite/auth/.secret
starter/lazysite/forms/.secret
starter/lazysite/forms/.rate-limit.db
starter/lazysite/forms/.smtp-password
starter/lazysite/forms/contact.conf
starter/lazysite/forms/handlers.conf
starter/lazysite/forms/smtp.conf
starter/lazysite/logs/
starter/lazysite/manager/locks/
starter/lazysite/cache/

# Manager CSS served copy (source is starter/lazysite/themes/manager/assets/)
starter/manager/assets/manager.css

# Compiled HTML cache files
starter/**/*.html

# Deployment-only rsync helper (lives at /srv/projects/lazysite/)
rsync-from-source.sh

# OS files
.DS_Store

# Release artefacts. dist/ root is ignored by default;
# make-release.sh force-adds the tarball + .sha256 via `git add -f`
# at release time. dist/config/ is explicitly tracked - it holds
# build inputs (classification.json, sbom-deps.json) alongside the
# build outputs.
dist/*
!dist/config/
!dist/config/*

# CC-authored release notes. Workflow state, not project history.
# make-release.sh --auto reads this file automatically and deletes
# it on successful push. See docs/development.md Releasing section.
.release-notes.md
