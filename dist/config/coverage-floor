# Coverage floors for `tools/coverage.sh --check`.
#
# Commercial-regime TARGET: 75% statements.
# Enforced regression floors: 60% statements AND 60% branches per
# cleanly-measured production CGI (eight-dimension review D3: the framework
# requires line and branch thresholds, not statements alone). Ratchet upward
# as coverage improves - never down.
#
# lazysite-auth.pl joined the gate 2026-07-02: its tests always ran it from
# the repo path, but they rebuilt %ENV from scratch and dropped PERL5OPT, so
# the instrumentation never reached the child ("not measured"). Fixed via
# TestHelper::env_passthrough() in every %ENV-rebuilding test.
#
# Measured baseline (full suite, subprocess-instrumented; 2026-07-02, after
# the eight-dimension-review hardening), statement / branch:
#
#   CGIs (the gate):
#     lazysite-dav.pl                 93% / 73%
#     lazysite-processor.pl           83% / 69%
#     lazysite-auth.pl                82% / 61%   <- newly gated (measured via
#                                                    env_passthrough; reported
#                                                    under the fake-repo copy path)
#     tools/lazysite-bundle-apply.pl  90% / 65%
#     tools/lazysite-users.pl         89% / 70%
#     lazysite-manager-api.pl         71% / 57-72% <- branch NOISY run-to-run;
#                                                     see the override below
#
#   Modules (in-process + now-measured subprocess handlers):
#     Util 100/92 · Auth::Acl 100/85 · Session 100/73 · Credential 100/72
#     Settings 96/69 · Audit 100/70 · Manager::Files 96/72 · Common 88/76
#     Upload 82/69 · Themes 76/52 · Layouts 75/54 · Plugins 66/43
#     Backups 70/56 · OAuth 88/50 · plugins/stats.pl 94/68
#
# NOTE (historical): Plugins/Upload previously measured 21/11 and 37/29 - an
# artifact of %ENV-rebuilding tests dropping PERL5OPT so subprocess children
# were never instrumented. TestHelper::env_passthrough() (2026-07-02) fixed
# the measurement; the handlers were always tested. install.pl remains outside
# the gate (its tests exercise a tempdir-copied tree end to end).
floor=60
branch_floor=60
# manager-api's BRANCH measurement is noisy under subprocess instrumentation:
# two same-code full runs (2026-07-02) measured 72.5% and 56.6% - the merged
# contribution of instrumented children varies (suspected: the 2 s plugin
# --describe alarm flips paths when instrumented children run slower, plus
# per-run merge loss). Statements are stable (70.9-75.4). Override the branch
# floor for this file only until the measurement is stabilised (backlog:
# subprocess-coverage stability); ratchet back to 60 then. Never lower others.
branch_floor[lazysite-manager-api.pl]=50
target=75
