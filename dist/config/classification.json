{
  "schema_version": "1",
  "_doc": "D021a + D022 classification config. Rules are tried in order; first match wins. Excludes are checked before rules. Overrides (by exact path) take precedence over everything.",
  "rules": [
    {
      "_comment": "D022: plugins/ is the canonical home for shipped plugins. Drops the lazysite- prefix; installed under DOCROOT/../plugins/ to match manager-api's @CANDIDATES search path.",
      "pattern": "^plugins/(.+\\.pl)$",
      "install_to": "{DOCROOT}/../plugins/$1",
      "bucket": "code"
    },
    {
      "_comment": "Core CGI scripts stay at repo root with the lazysite- prefix. processor, auth, manager-api are explicitly enumerated so a future stray lazysite-*.pl at root won't get silently installed to cgi-bin.",
      "pattern": "^lazysite-(processor|auth|manager-api)\\.pl$",
      "install_to": "{CGIBIN}/$0",
      "bucket": "code"
    },
    {
      "pattern": "^tools/lazysite-users\\.pl$",
      "install_to": "{DOCROOT}/../tools/lazysite-users.pl",
      "bucket": "code"
    },
    {
      "pattern": "^tools/lazysite-server\\.pl$",
      "install_to": "{DOCROOT}/../tools/lazysite-server.pl",
      "bucket": "code"
    },
    {
      "pattern": "^tools/build-static\\.sh$",
      "install_to": "{DOCROOT}/../tools/build-static.sh",
      "bucket": "code"
    },
    {
      "pattern": "^starter/manager/(.+)$",
      "install_to": "{DOCROOT}/manager/$1",
      "bucket": "code"
    },
    {
      "_comment": "D013: manager UI template + CSS assets live outside both layouts/ and themes/. Manager is internal plumbing, not a themeable layout.",
      "pattern": "^starter/lazysite/manager/(.+)$",
      "install_to": "{DOCROOT}/lazysite/manager/$1",
      "bucket": "code"
    },
    {
      "_comment": "D022: registries source path now matches install destination. One rule replaces the previous rule-pair.",
      "pattern": "^starter/lazysite/templates/registries/(.+)$",
      "install_to": "{DOCROOT}/lazysite/templates/registries/$1",
      "bucket": "seed"
    },
    {
      "pattern": "^starter/lazysite/forms/(.+)\\.conf\\.example$",
      "install_to": "{DOCROOT}/lazysite/forms/$1.conf",
      "bucket": "seed"
    },
    {
      "pattern": "^starter/lazysite/auth/(.+)\\.example$",
      "install_to": "{DOCROOT}/lazysite/auth/$1.example",
      "bucket": "seed"
    },
    {
      "pattern": "^starter/lazysite\\.conf\\.example$",
      "install_to": "{DOCROOT}/lazysite/lazysite.conf.example",
      "bucket": "seed"
    },
    {
      "pattern": "^starter/nav\\.conf\\.example$",
      "install_to": "{DOCROOT}/lazysite/nav.conf.example",
      "bucket": "seed"
    },
    {
      "pattern": "^starter/docs/(.+)$",
      "install_to": "{DOCROOT}/docs/$1",
      "bucket": "seed"
    },
    {
      "pattern": "^starter/(.+\\.md)$",
      "install_to": "{DOCROOT}/$1",
      "bucket": "seed"
    },
    {
      "pattern": "^installers/hestia/(.+)$",
      "install_to": null,
      "bucket": "code"
    },
    {
      "pattern": "^install\\.(sh|pl)$",
      "install_to": null,
      "bucket": "code"
    },
    {
      "_comment": "Root-of-tarball docs including UPGRADE.md from 0.2.0 onwards.",
      "pattern": "^(LICENSE|README\\.md|SECURITY\\.md|UPGRADE\\.md)$",
      "install_to": null,
      "bucket": "code"
    }
  ],
  "exclude": [
    "^Makefile$",
    "^NEXT_VERSION$",
    "^VERSION$",
    "^\\.git/",
    "^\\.github/",
    "^\\.gitignore$",
    "^\\.release-notes\\.md$",
    "^\\.release-prep\\.sh$",
    "^\\.rsyncignore$",
    "^dist/",
    "^docs/architecture/",
    "^docs/development\\.md$",
    "^installers/docker/",
    "^release-manifest\\.json$",
    "^sbom\\.json$",
    "^tools/commit\\.sh$",
    "^tools/release\\.sh$",
    "^starter/.*\\.html$",
    "^starter/lazysite/auth/\\.gitkeep$",
    "^starter/lazysite/forms/contact\\.conf$",
    "^starter/lazysite/forms/handlers\\.conf$",
    "^starter/lazysite/lazysite\\.conf$",
    "^starter/lazysite/nav\\.conf$",
    "^t/",
    "^tools/build-manifest\\.pl$",
    "^tools/manifest-to-sbom\\.pl$",
    "^website/"
  ],
  "overrides": [],
  "runtime_paths": [
    {
      "path": "{DOCROOT}/lazysite/auth",
      "mode": "0750",
      "purpose": "user credentials, session secret, login rate-limit DB"
    },
    {
      "path": "{DOCROOT}/lazysite/cache",
      "mode": "0755",
      "purpose": "rendered HTML cache"
    },
    {
      "path": "{DOCROOT}/lazysite/logs",
      "mode": "0755",
      "purpose": "application log output"
    },
    {
      "path": "{DOCROOT}/lazysite/manager/locks",
      "mode": "0755",
      "purpose": "per-file edit locks"
    },
    {
      "path": "{DOCROOT}/../plugins",
      "mode": "0755",
      "purpose": "plugin scripts (D022)"
    },
    {
      "path": "{DOCROOT}/lazysite/layouts",
      "mode": "0755",
      "purpose": "layouts + nested themes (D013)"
    },
    {
      "path": "{DOCROOT}/lazysite-assets",
      "mode": "0755",
      "purpose": "web-served theme assets (D013 nested under LAYOUT/THEME/)"
    }
  ]
}
