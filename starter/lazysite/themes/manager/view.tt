<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>[% page_title %][% IF site_name %] - [% site_name %][% END %]</title>
  <link rel="stylesheet" href="/manager/assets/manager.css">
  <script>
  // M-1: manager CSRF wrapper. Must run BEFORE any script inside <main>
  // that calls fetch(), otherwise page-onload calls (loadUsers,
  // loadSiteSettings, loadCache, etc.) will capture the original
  // window.fetch reference at call time and bypass the wrapper - so
  // their POSTs go out without X-CSRF-Token and the server rejects
  // them. Placing this in <head> means window.fetch is replaced before
  // the HTML parser has even reached <body>.
  //
  // The wrapper itself kicks off an asynchronous csrf-token fetch and
  // attaches the resolved token as X-CSRF-Token on every POST to the
  // manager API. Page scripts do not need to await anything; each POST
  // waits for lazysiteCsrfReady() internally.
  (function(){
    var MGR_API = '/cgi-bin/lazysite-manager-api.pl';
    var tokenPromise = fetch(MGR_API + '?action=csrf-token', { credentials: 'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(d){ window.LAZYSITE_CSRF = (d && d.token) || ''; return window.LAZYSITE_CSRF; })
      .catch(function(){ window.LAZYSITE_CSRF = ''; return ''; });
    window.lazysiteCsrfReady = function(){ return tokenPromise; };

    var origFetch = window.fetch.bind(window);
    window.fetch = function(resource, init){
      init = init || {};
      var method = (init.method || 'GET').toUpperCase();
      var url    = typeof resource === 'string' ? resource : (resource && resource.url) || '';
      if ( method !== 'POST' || url.indexOf(MGR_API) !== 0 ) {
        return origFetch(resource, init);
      }
      var h = new Headers(init.headers || {});
      var init2 = {};
      for ( var k in init ) { if ( init.hasOwnProperty(k) ) init2[k] = init[k]; }
      init2.headers = h;
      return window.lazysiteCsrfReady().then(function(token){
        if ( token && !h.has('X-CSRF-Token') ) h.set('X-CSRF-Token', token);
        return origFetch(resource, init2);
      });
    };
  })();
  </script>
</head>
<body class="mg-body">

<header class="mg-header">
  <div class="mg-header-inner">
    <a href="/" class="mg-brand">[% site_name || 'Site' %]</a>
    <nav class="mg-nav" aria-label="Manager navigation">
      <a href="/manager"
         [% IF request_uri == '/manager' || request_uri == '/manager/' || request_uri.match('^/manager/config') %]
         class="active" aria-current="page"
         [% END %]>Config</a>
      <a href="/manager/files"
         [% IF request_uri.match('^/manager/files') %]
         class="active" aria-current="page"
         [% END %]>Files</a>
      <a href="/manager/nav"
         [% IF request_uri.match('^/manager/nav') %]
         class="active" aria-current="page"
         [% END %]>Nav</a>
      <a href="/manager/plugins"
         [% IF request_uri.match('^/manager/plugins') %]
         class="active" aria-current="page"
         [% END %]>Plugins</a>
      <a href="/manager/themes"
         [% IF request_uri.match('^/manager/themes') %]
         class="active" aria-current="page"
         [% END %]>Themes</a>
      <a href="/manager/users"
         [% IF request_uri.match('^/manager/users') %]
         class="active" aria-current="page"
         [% END %]>Users</a>
      <a href="/manager/cache"
         [% IF request_uri.match('^/manager/cache') %]
         class="active" aria-current="page"
         [% END %]>Cache</a>
    </nav>
    <div class="mg-header-tools">
      [% IF authenticated %]
      <span class="mg-user">[% auth_name || auth_user %]</span>
      [% IF no_password %]
      <span class="mg-no-password-warn">
        &#9888; No password set.
        <a href="/manager/users">Set one</a>
      </span>
      [% END %]
      <a href="/cgi-bin/lazysite-auth.pl?action=logout" class="mg-signout">Sign out</a>
      [% END %]
      <a href="/manager" class="mg-brand">Lazysite Manager</a>
    </div>
  </div>
</header>

<main class="mg-main">
  [% content %]
</main>

</body>
</html>
