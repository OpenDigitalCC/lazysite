# lazysite demo users - copy to 'users' to enable auth
# Format: username:sha256hex(password)
# Generate a hash: echo -n 'password' | sha256sum | cut -d' ' -f1
# An empty password field means the account has no password set.
# Such accounts can only sign in from localhost (127.0.0.1, ::1)
# and will see a warning prompting them to set one.
manager:
