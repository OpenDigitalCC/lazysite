<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>[% page_title %][% IF site_name %] - [% site_name %][% END %]</title>
  <link rel="stylesheet" href="/manager/assets/manager.css">
  <script>
  // M-1: manager CSRF wrapper. Must run BEFORE any script inside <main>
  // that calls fetch(), otherwise page-onload calls (loadUsers,
  // loadSiteSettings, loadCache, etc.) will capture the original
  // window.fetch reference at call time and bypass the wrapper - so
  // their POSTs go out without X-CSRF-Token and the server rejects
  // them. Placing this in <head> means window.fetch is replaced before
  // the HTML parser has even reached <body>.
  //
  // The wrapper itself kicks off an asynchronous csrf-token fetch and
  // attaches the resolved token as X-CSRF-Token on every POST to the
  // manager API. Page scripts do not need to await anything; each POST
  // waits for lazysiteCsrfReady() internally.
  // Global warning bar helpers. Pages call mgShowWarning(msg, isError)
  // on any {ok:0} or network failure, and mgClearWarning() on success.
  window.mgShowWarning = function(msg, isError) {
    var bar = document.getElementById('mg-warning-bar');
    var txt = document.getElementById('mg-warning-bar-msg');
    if (!bar || !txt) return;
    txt.textContent = msg || '';
    bar.className = 'mg-warning-bar' + (isError ? ' mg-warning-error' : '');
    bar.style.display = 'flex';
  };
  window.mgClearWarning = function() {
    var bar = document.getElementById('mg-warning-bar');
    if (bar) bar.style.display = 'none';
  };

  // SM109 phase 2: toast notifications + a styled confirm/prompt modal, replacing
  // the warning bar and the native confirm()/prompt(). mgShowWarning and the pages'
  // showStatus route to a toast, so existing feedback call sites need no change.
  window.mgToast = function(msg, kind) {
    var host = document.getElementById('mg-toasts');
    if (!host) { host = document.createElement('div'); host.id = 'mg-toasts'; document.body.appendChild(host); }
    var t = document.createElement('div');
    t.className = 'mg-toast' + (kind ? ' mg-toast-' + kind : '');
    t.setAttribute('role', kind === 'error' ? 'alert' : 'status');
    t.textContent = msg || '';
    host.appendChild(t);
    requestAnimationFrame(function(){ t.classList.add('mg-toast-in'); });
    var ttl = (kind === 'error') ? 6000 : 3500;
    setTimeout(function(){
      t.classList.remove('mg-toast-in');
      setTimeout(function(){ if (t.parentNode) t.parentNode.removeChild(t); }, 250);
    }, ttl);
  };
  window.mgShowWarning  = function(msg, isError){ window.mgToast(msg, isError ? 'error' : 'success'); };
  window.mgClearWarning = function(){};
  window.showStatus     = function(msg, isError){ window.mgToast(msg, isError ? 'error' : 'success'); };

  // Promise-based modal: resolves true/false (confirm) or string/null (prompt).
  function mgModal(opts) {
    return new Promise(function(resolve){
      var ov = document.createElement('div'); ov.className = 'mg-modal-overlay';
      var box = document.createElement('div'); box.className = 'mg-modal';
      var okClass = opts.danger ? ' mg-btn-danger' : ' mg-btn-primary';
      box.innerHTML =
        '<div class="mg-modal-msg"></div>' +
        (opts.prompt ? '<input class="mg-inp mg-modal-input" type="text">' : '') +
        '<div class="mg-modal-actions">' +
          '<button class="mg-btn mg-btn-outline mg-modal-cancel"></button>' +
          '<button class="mg-btn' + okClass + ' mg-modal-ok"></button>' +
        '</div>';
      box.querySelector('.mg-modal-msg').textContent = opts.msg || '';
      box.querySelector('.mg-modal-cancel').textContent = opts.cancel || 'Cancel';
      box.querySelector('.mg-modal-ok').textContent = opts.ok || 'OK';
      ov.appendChild(box); document.body.appendChild(ov);
      var input = box.querySelector('.mg-modal-input');
      if (input) { input.value = (opts.value != null ? opts.value : ''); setTimeout(function(){ input.focus(); input.select(); }, 30); }
      requestAnimationFrame(function(){ ov.classList.add('mg-modal-in'); });
      function onKey(e){
        if (e.key === 'Escape') close(opts.prompt ? null : false);
        else if (e.key === 'Enter') close(opts.prompt ? (input ? input.value : '') : true);
      }
      function close(val){
        document.removeEventListener('keydown', onKey);
        ov.classList.remove('mg-modal-in');
        setTimeout(function(){ if (ov.parentNode) ov.parentNode.removeChild(ov); }, 200);
        resolve(val);
      }
      document.addEventListener('keydown', onKey);
      box.querySelector('.mg-modal-ok').onclick = function(){ close(opts.prompt ? (input ? input.value : '') : true); };
      box.querySelector('.mg-modal-cancel').onclick = function(){ close(opts.prompt ? null : false); };
      ov.addEventListener('click', function(e){ if (e.target === ov) close(opts.prompt ? null : false); });
    });
  }
  window.mgConfirm = function(msg, opts){ opts = opts || {}; return mgModal({ msg: msg, ok: opts.ok || 'Confirm', danger: opts.danger }); };
  window.mgPrompt  = function(msg, value){ return mgModal({ msg: msg, prompt: true, value: value, ok: 'OK' }); };

  (function(){
    var MGR_API = '/cgi-bin/lazysite-manager-api.pl';
    var tokenPromise = fetch(MGR_API + '?action=csrf-token', { credentials: 'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(d){ window.LAZYSITE_CSRF = (d && d.token) || ''; return window.LAZYSITE_CSRF; })
      .catch(function(){ window.LAZYSITE_CSRF = ''; return ''; });
    window.lazysiteCsrfReady = function(){ return tokenPromise; };

    var origFetch = window.fetch.bind(window);
    window.fetch = function(resource, init){
      init = init || {};
      var method = (init.method || 'GET').toUpperCase();
      var url    = typeof resource === 'string' ? resource : (resource && resource.url) || '';
      if ( method !== 'POST' || url.indexOf(MGR_API) !== 0 ) {
        return origFetch(resource, init);
      }
      var h = new Headers(init.headers || {});
      var init2 = {};
      for ( var k in init ) { if ( init.hasOwnProperty(k) ) init2[k] = init[k]; }
      init2.headers = h;
      return window.lazysiteCsrfReady().then(function(token){
        if ( token && !h.has('X-CSRF-Token') ) h.set('X-CSRF-Token', token);
        return origFetch(resource, init2);
      });
    };
  })();
  </script>
</head>
<body class="mg-body">

<header class="mg-header">
  <div class="mg-header-inner">
    <a href="/" class="mg-brand">[% site_name || 'Site' %]</a>
    <nav class="mg-nav" aria-label="Manager navigation">
      <a href="/manager"
         [% IF request_uri == '/manager' || request_uri == '/manager/' || request_uri.match('^/manager/config') %]
         class="active" aria-current="page"
         [% END %]>Config</a>
      <a href="/manager/files"
         [% IF request_uri.match('^/manager/files') %]
         class="active" aria-current="page"
         [% END %]>Files</a>
      <a href="/manager/nav"
         [% IF request_uri.match('^/manager/nav') %]
         class="active" aria-current="page"
         [% END %]>Nav</a>
      <a href="/manager/plugins"
         [% IF request_uri.match('^/manager/plugins') %]
         class="active" aria-current="page"
         [% END %]>Plugins</a>
      <a href="/manager/themes"
         [% IF request_uri.match('^/manager/themes') %]
         class="active" aria-current="page"
         [% END %]>Themes</a>
      <a href="/manager/users"
         [% IF request_uri.match('^/manager/users') %]
         class="active" aria-current="page"
         [% END %]>Users</a>
      <a href="/manager/cache"
         [% IF request_uri.match('^/manager/cache') %]
         class="active" aria-current="page"
         [% END %]>Cache</a>
      <a href="/manager/backups"
         [% IF request_uri.match('^/manager/backups') %]
         class="active" aria-current="page"
         [% END %]>Backups</a>
      <a href="/manager/audit"
         [% IF request_uri.match('^/manager/audit') %]
         class="active" aria-current="page"
         [% END %]>Audit</a>
    </nav>
    <div class="mg-header-tools">
      [% IF authenticated %]
      <span class="mg-user">[% auth_name || auth_user %]</span>
      [% IF no_password %]
      <span class="mg-no-password-warn">
        &#9888; No password set.
        <a href="/manager/users">Set one</a>
      </span>
      [% END %]
      <a href="/cgi-bin/lazysite-auth.pl?action=logout" class="mg-signout">Sign out</a>
      [% END %]
      <a href="/manager" class="mg-brand">Lazysite Manager</a>
    </div>
  </div>
</header>

<div id="mg-warning-bar" class="mg-warning-bar" style="display:none">
  <span id="mg-warning-bar-msg"></span>
  <button onclick="mgClearWarning()" class="mg-warning-bar-close" aria-label="Dismiss">x</button>
</div>

<main class="mg-main">
  [% content %]
</main>

<footer class="mg-foot" style="text-align:center;padding:1rem;color:#999;font-size:0.8rem;">
  <span id="mg-version">lazysite</span>
</footer>
<script>
(function () {
  fetch('/cgi-bin/lazysite-manager-api.pl?action=version')
    .then(function (r) { return r.json(); })
    .then(function (d) {
      var e = document.getElementById('mg-version');
      if (e && d && d.version) { e.textContent = 'lazysite v' + d.version; }
    })
    .catch(function () {});
})();
</script>

</body>
</html>
