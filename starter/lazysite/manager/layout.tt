<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>[% page_title %][% IF site_name %] - [% site_name %][% END %]</title>
  <link rel="stylesheet" href="/manager/assets/manager.css?v=[% lazysite_version %]">
  <script>
  // SM109 phase 6: set the theme before first paint (no flash). Saved choice wins,
  // else follow the OS preference.
  (function(){
    try {
      var t = localStorage.getItem('mg-theme');
      if (t !== 'dark' && t !== 'light') {
        t = (window.matchMedia && matchMedia('(prefers-color-scheme: dark)').matches) ? 'dark' : 'light';
      }
      document.documentElement.setAttribute('data-theme', t);
    } catch (e) {}
  })();
  window.mgToggleTheme = function(){
    var next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    try { localStorage.setItem('mg-theme', next); } catch (e) {}
  };

  // M-1: manager CSRF wrapper. Must run BEFORE any script inside <main>
  // that calls fetch(), otherwise page-onload calls (loadUsers,
  // loadSiteSettings, loadCache, etc.) will capture the original
  // window.fetch reference at call time and bypass the wrapper - so
  // their POSTs go out without X-CSRF-Token and the server rejects
  // them. Placing this in <head> means window.fetch is replaced before
  // the HTML parser has even reached <body>.
  //
  // The wrapper itself kicks off an asynchronous csrf-token fetch and
  // attaches the resolved token as X-CSRF-Token on every POST to the
  // manager API. Page scripts do not need to await anything; each POST
  // waits for lazysiteCsrfReady() internally.
  // Global warning bar helpers. Pages call mgShowWarning(msg, isError)
  // on any {ok:0} or network failure, and mgClearWarning() on success.
  window.mgShowWarning = function(msg, isError) {
    var bar = document.getElementById('mg-warning-bar');
    var txt = document.getElementById('mg-warning-bar-msg');
    if (!bar || !txt) return;
    txt.textContent = msg || '';
    bar.className = 'mg-warning-bar' + (isError ? ' mg-warning-error' : '');
    bar.style.display = 'flex';
  };
  window.mgClearWarning = function() {
    var bar = document.getElementById('mg-warning-bar');
    if (bar) bar.style.display = 'none';
  };

  // SM109 phase 2: toast notifications + a styled confirm/prompt modal, replacing
  // the warning bar and the native confirm()/prompt(). mgShowWarning and the pages'
  // showStatus route to a toast, so existing feedback call sites need no change.
  window.mgToast = function(msg, kind) {
    var host = document.getElementById('mg-toasts');
    if (!host) { host = document.createElement('div'); host.id = 'mg-toasts'; document.body.appendChild(host); }
    var t = document.createElement('div');
    t.className = 'mg-toast' + (kind ? ' mg-toast-' + kind : '');
    t.setAttribute('role', kind === 'error' ? 'alert' : 'status');
    t.textContent = msg || '';
    host.appendChild(t);
    requestAnimationFrame(function(){ t.classList.add('mg-toast-in'); });
    var ttl = (kind === 'error') ? 6000 : 3500;
    setTimeout(function(){
      t.classList.remove('mg-toast-in');
      setTimeout(function(){ if (t.parentNode) t.parentNode.removeChild(t); }, 250);
    }, ttl);
  };
  window.mgShowWarning  = function(msg, isError){ window.mgToast(msg, isError ? 'error' : 'success'); };
  window.mgClearWarning = function(){};
  window.showStatus     = function(msg, isError){ window.mgToast(msg, isError ? 'error' : 'success'); };

  // Promise-based modal: resolves true/false (confirm) or string/null (prompt).
  function mgModal(opts) {
    return new Promise(function(resolve){
      var ov = document.createElement('div'); ov.className = 'mg-modal-overlay';
      var box = document.createElement('div'); box.className = 'mg-modal';
      var okClass = opts.danger ? ' mg-btn-danger' : ' mg-btn-primary';
      box.innerHTML =
        '<div class="mg-modal-msg"></div>' +
        (opts.prompt ? '<input class="mg-inp mg-modal-input" type="text">' : '') +
        '<div class="mg-modal-actions">' +
          '<button class="mg-btn mg-btn-outline mg-modal-cancel"></button>' +
          '<button class="mg-btn' + okClass + ' mg-modal-ok"></button>' +
        '</div>';
      box.querySelector('.mg-modal-msg').textContent = opts.msg || '';
      box.querySelector('.mg-modal-cancel').textContent = opts.cancel || 'Cancel';
      box.querySelector('.mg-modal-ok').textContent = opts.ok || 'OK';
      ov.appendChild(box); document.body.appendChild(ov);
      var input = box.querySelector('.mg-modal-input');
      if (input) { input.value = (opts.value != null ? opts.value : ''); setTimeout(function(){ input.focus(); input.select(); }, 30); }
      requestAnimationFrame(function(){ ov.classList.add('mg-modal-in'); });
      function onKey(e){
        if (e.key === 'Escape') close(opts.prompt ? null : false);
        else if (e.key === 'Enter') close(opts.prompt ? (input ? input.value : '') : true);
      }
      function close(val){
        document.removeEventListener('keydown', onKey);
        ov.classList.remove('mg-modal-in');
        setTimeout(function(){ if (ov.parentNode) ov.parentNode.removeChild(ov); }, 200);
        resolve(val);
      }
      document.addEventListener('keydown', onKey);
      box.querySelector('.mg-modal-ok').onclick = function(){ close(opts.prompt ? (input ? input.value : '') : true); };
      box.querySelector('.mg-modal-cancel').onclick = function(){ close(opts.prompt ? null : false); };
      ov.addEventListener('click', function(e){ if (e.target === ov) close(opts.prompt ? null : false); });
    });
  }
  window.mgConfirm = function(msg, opts){ opts = opts || {}; return mgModal({ msg: msg, ok: opts.ok || 'Confirm', danger: opts.danger }); };
  window.mgPrompt  = function(msg, value){ return mgModal({ msg: msg, prompt: true, value: value, ok: 'OK' }); };

  // SM109 phase 5: command palette (Ctrl/Cmd-K) - jump to a page or run a command.
  window.MG_DESTINATIONS = [
    { label: 'Config',     url: '/manager' },
    { label: 'Files',      url: '/manager/files' },
    { label: 'Navigation', url: '/manager/nav' },
    { label: 'Appearance', url: '/manager/appearance' },
    { label: 'Plugin Manager', url: '/manager/plugins' },
    { label: 'Plugin Config',  url: '/manager/plugin-config' },
    { label: 'Users',      url: '/manager/users' },
    { label: 'Cache',      url: '/manager/cache' },
    { label: 'Backups',    url: '/manager/backups' },
    { label: 'Audit',      url: '/manager/audit' },
    { label: 'Stats',      url: '/manager/stats' },
    { label: 'View site',  url: '/' },
    { label: 'Toggle dark mode', action: 'theme' },
    { label: 'Sign out',   url: '/cgi-bin/lazysite-auth.pl?action=logout' }
  ];
  window.mgPaletteOpen = function(){
    if (document.getElementById('mg-palette-ov')) return;
    var ov = document.createElement('div'); ov.id = 'mg-palette-ov'; ov.className = 'mg-palette-overlay';
    ov.innerHTML = '<div class="mg-palette"><input class="mg-palette-input" type="text" ' +
      'placeholder="Jump to a page or run a command…" aria-label="Command palette">' +
      '<div class="mg-palette-list" role="listbox"></div></div>';
    document.body.appendChild(ov);
    var input = ov.querySelector('.mg-palette-input');
    var list  = ov.querySelector('.mg-palette-list');
    var sel = 0, filtered = [];
    function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    function render(){
      var q = (input.value || '').toLowerCase();
      filtered = window.MG_DESTINATIONS.filter(function(d){ return d.label.toLowerCase().indexOf(q) !== -1; });
      if (sel >= filtered.length) sel = Math.max(0, filtered.length - 1);
      list.innerHTML = filtered.length ? filtered.map(function(d, i){
        return '<div class="mg-palette-item' + (i === sel ? ' sel' : '') + '" data-i="' + i + '">' +
          '<span>' + esc(d.label) + '</span>' +
          (d.url ? '<span class="mg-palette-url">' + esc(d.url) + '</span>' : '') + '</div>';
      }).join('') : '<div class="mg-palette-empty">No matches</div>';
    }
    function go(d){ if (!d) return; close(); if (d.action === 'theme') { window.mgToggleTheme(); } else if (d.url) { location.href = d.url; } }
    function close(){ if (ov.parentNode) ov.parentNode.removeChild(ov); document.removeEventListener('keydown', onKey, true); }
    function onKey(e){
      if (e.key === 'Escape') { e.preventDefault(); close(); }
      else if (e.key === 'ArrowDown') { e.preventDefault(); sel = Math.min(filtered.length - 1, sel + 1); render(); }
      else if (e.key === 'ArrowUp')   { e.preventDefault(); sel = Math.max(0, sel - 1); render(); }
      else if (e.key === 'Enter')     { e.preventDefault(); go(filtered[sel]); }
    }
    document.addEventListener('keydown', onKey, true);
    input.addEventListener('input', function(){ sel = 0; render(); });
    list.addEventListener('click', function(e){ var it = e.target.closest('.mg-palette-item'); if (it) go(filtered[+it.getAttribute('data-i')]); });
    ov.addEventListener('click', function(e){ if (e.target === ov) close(); });
    render(); input.focus();
  };
  document.addEventListener('keydown', function(e){
    if ((e.metaKey || e.ctrlKey) && (e.key === 'k' || e.key === 'K')) { e.preventDefault(); window.mgPaletteOpen(); }
  });

  (function(){
    var MGR_API = '/cgi-bin/lazysite-manager-api.pl';
    var tokenPromise = fetch(MGR_API + '?action=csrf-token', { credentials: 'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(d){ window.LAZYSITE_CSRF = (d && d.token) || ''; return window.LAZYSITE_CSRF; })
      .catch(function(){ window.LAZYSITE_CSRF = ''; return ''; });
    window.lazysiteCsrfReady = function(){ return tokenPromise; };

    var origFetch = window.fetch.bind(window);
    window.fetch = function(resource, init){
      init = init || {};
      var method = (init.method || 'GET').toUpperCase();
      var url    = typeof resource === 'string' ? resource : (resource && resource.url) || '';
      if ( method !== 'POST' || url.indexOf(MGR_API) !== 0 ) {
        return origFetch(resource, init);
      }
      var h = new Headers(init.headers || {});
      var init2 = {};
      for ( var k in init ) { if ( init.hasOwnProperty(k) ) init2[k] = init[k]; }
      init2.headers = h;
      return window.lazysiteCsrfReady().then(function(token){
        if ( token && !h.has('X-CSRF-Token') ) h.set('X-CSRF-Token', token);
        return origFetch(resource, init2);
      });
    };
  })();

  // SM113: operator notifications (poll-based). Badge shows the unread count;
  // opening the panel marks everything seen. Both endpoints are GET (CSRF-exempt;
  // the seen-marker is a harmless per-operator write).
  (function () {
    if (!document.getElementById('mg-notif')) return;
    var API = '/cgi-bin/lazysite-manager-api.pl';
    function nesc(s){ var d=document.createElement('div'); d.textContent=(s==null?'':String(s)); return d.innerHTML; }
    function nago(ts){ var s=Math.floor(Date.now()/1000-(ts||0)); if(s<60)return'just now'; if(s<3600)return Math.floor(s/60)+'m ago'; if(s<86400)return Math.floor(s/3600)+'h ago'; return Math.floor(s/86400)+'d ago'; }
    var notices = [];
    function setBadge(n){ var b=document.getElementById('mg-notif-badge'); if(!b)return; if(n>0){b.textContent=n>99?'99+':n; b.hidden=false;} else {b.hidden=true;} }
    function load(){
      fetch(API + '?action=notices').then(function(r){return r.json();}).then(function(d){
        if (!d || !d.ok) return; notices = d.notices || []; setBadge(d.unread || 0);
      }).catch(function(){});
    }
    window.mgToggleNotif = function(){
      var panel = document.getElementById('mg-notif-panel'); if (!panel) return;
      if (!panel.hidden) { panel.hidden = true; return; }
      panel.innerHTML = notices.length ? notices.map(function(n){
        var inner = '<div class="mg-notif-msg">' + nesc(n.message||'') + '</div>'
                  + '<div class="mg-notif-time">' + nesc(nago(n.ts)) + '</div>';
        return n.url ? '<a class="mg-notif-item" href="'+nesc(n.url)+'">'+inner+'</a>'
                     : '<div class="mg-notif-item">'+inner+'</div>';
      }).join('') : '<div class="mg-notif-empty">No notifications.</div>';
      panel.hidden = false;
      fetch(API + '?action=notices-seen').then(function(){ setBadge(0); }).catch(function(){});
    };
    document.addEventListener('click', function(e){
      var wrap=document.getElementById('mg-notif'), panel=document.getElementById('mg-notif-panel');
      if (wrap && panel && !panel.hidden && !wrap.contains(e.target)) panel.hidden = true;
    });
    load();
  })();
  </script>
</head>
<body class="mg-body">

<header class="mg-header">
  <div class="mg-header-inner">
    <a href="/" class="mg-brand">[% site_name || 'Site' %]</a>
    <button type="button" class="mg-palette-btn" onclick="mgPaletteOpen()" aria-label="Open command palette">
      <span>Jump to&hellip;</span><kbd>Ctrl K</kbd>
    </button>
    <div class="mg-header-tools">
      <button type="button" class="mg-theme-toggle" onclick="mgToggleTheme()" title="Toggle light / dark" aria-label="Toggle light / dark">&#9681;</button>
      [% IF authenticated %]
      <div class="mg-notif" id="mg-notif">
        <button type="button" class="mg-notif-btn" onclick="mgToggleNotif()" title="Notifications" aria-label="Notifications">&#128276;<span class="mg-notif-badge" id="mg-notif-badge" hidden>0</span></button>
        <div class="mg-notif-panel" id="mg-notif-panel" hidden></div>
      </div>
      <span class="mg-user">[% auth_name || auth_user %]</span>
      [% IF no_password %]
      <span class="mg-no-password-warn">
        &#9888; No password set.
        <a href="/manager/users">Set one</a>
      </span>
      [% END %]
      <a href="/cgi-bin/lazysite-auth.pl?action=logout" class="mg-signout">Sign out</a>
      [% END %]
      <a href="/manager" class="mg-brand">Lazysite Manager</a>
    </div>
  </div>
</header>

<div id="mg-warning-bar" class="mg-warning-bar" style="display:none">
  <span id="mg-warning-bar-msg"></span>
  <button onclick="mgClearWarning()" class="mg-warning-bar-close" aria-label="Dismiss">x</button>
</div>

<div class="mg-shell">
  <aside class="mg-sidebar">
    <nav class="mg-nav" aria-label="Manager navigation">
      <div class="mg-nav-group">Content</div>
      <a href="/manager/files" [% IF request_uri.match('^/manager/files') %]class="active" aria-current="page"[% END %]>Files</a>
      <a href="/manager/nav" [% IF request_uri.match('^/manager/nav') %]class="active" aria-current="page"[% END %]>Navigation</a>
      <a href="/manager/appearance" [% IF request_uri.match('^/manager/(appearance|themes)') %]class="active" aria-current="page"[% END %]>Appearance</a>
      <a href="/manager/plugins" [% IF request_uri.match('^/manager/plugins$') %]class="active" aria-current="page"[% END %]>Plugin Manager</a>
      <a href="/manager/plugin-config" [% IF request_uri.match('^/manager/plugin-config') %]class="active" aria-current="page"[% END %]>Plugin Config</a>
      <div class="mg-nav-group">Access</div>
      <a href="/manager/users" [% IF request_uri.match('^/manager/users') %]class="active" aria-current="page"[% END %]>Users</a>
      <div class="mg-nav-group">System</div>
      <a href="/manager" [% IF request_uri == '/manager' || request_uri == '/manager/' || request_uri.match('^/manager/config') %]class="active" aria-current="page"[% END %]>Config</a>
      <a href="/manager/cache" [% IF request_uri.match('^/manager/cache') %]class="active" aria-current="page"[% END %]>Cache</a>
      <a href="/manager/backups" [% IF request_uri.match('^/manager/backups') %]class="active" aria-current="page"[% END %]>Backups</a>
      <a href="/manager/audit" [% IF request_uri.match('^/manager/audit') %]class="active" aria-current="page"[% END %]>Audit</a>
      <a href="/manager/stats" [% IF request_uri.match('^/manager/stats') %]class="active" aria-current="page"[% END %]>Stats</a>
    </nav>
  </aside>
  <main class="mg-main">
    [% content %]
  </main>
</div>

<footer class="mg-foot" style="text-align:center;padding:1rem;font-size:0.8rem;">
  <span id="mg-version">lazysite</span>
</footer>
<script>
(function () {
  fetch('/cgi-bin/lazysite-manager-api.pl?action=version')
    .then(function (r) { return r.json(); })
    .then(function (d) {
      var e = document.getElementById('mg-version');
      if (e && d && d.version) { e.textContent = 'lazysite v' + d.version; }
    })
    .catch(function () {});
})();
</script>

</body>
</html>
