# lazysite.conf - site configuration
# See https://lazysite.io/docs for reference

site_name: My Site
site_url: ${REQUEST_SCHEME}://${SERVER_NAME}

manager: enabled
manager_path: /manager

# External authentication proxy trust (default: false)
# Set to true only when using an upstream proxy that validates
# credentials and sets X-Remote-User after authentication
# (e.g. mod_auth_mellon, Authelia, oauth2-proxy, nginx auth_request).
# When false (default), X-Remote-User from clients is ignored.
# lazysite-auth.pl sets LAZYSITE_AUTH_TRUSTED=1 internally after
# cookie validation, so it does not need this flag.
# auth_proxy_trusted: false

# Plugins are auto-discovered from cgi-bin/ and tools/.
# Scripts with --describe support appear in the manager.
# Use the manager Plugins page to enable or disable them.
# To pre-enable plugins without using the manager:
# plugins:
#   - cgi-bin/lazysite-form-smtp.pl
#   - tools/lazysite-audit.pl

# Manager limits (defaults shown).
# manager_upload_max_mb caps a single multipart upload request.
# manager_blocked_paths: comma-separated prefixes under DOCROOT
#   that reject save, delete, download, and upload (on top of the
#   built-in blocks). The "manager" prefix protects the manager UI
#   from editing itself into a broken state; remove it if you want
#   to edit manager pages via the manager.
#   (Old name manager_upload_blocked_paths is still accepted for
#   backward compatibility, with a deprecation log on startup.)
# manager_upload_blocked_extensions: comma-separated, no dots.
#   Applies to uploads only - no reason to block downloading a
#   file the operator already placed on disk.
# manager_upload_rate_count / manager_upload_rate_mb: per-user
#   hourly upload budget (0 disables that dimension).
# manager_upload_max_mb: 10
# manager_blocked_paths: lazysite/auth,lazysite/forms,lazysite/cache,lazysite/themes/manager,cgi-bin,manager
# manager_upload_blocked_extensions: pl,cgi
# manager_upload_rate_count: 60
# manager_upload_rate_mb: 500
