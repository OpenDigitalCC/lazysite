# Workflow and operator state that should NOT rsync
# from CC's sandbox to Stuart's environment.
# Stuart uses this with:
#     rsync -av --exclude-from=.rsyncignore ...

# Project version state: Stuart owns these.
VERSION
NEXT_VERSION

# Runtime operator conf for live sites:
starter/lazysite/lazysite.conf
starter/lazysite/nav.conf
starter/lazysite/forms/contact.conf
starter/lazysite/forms/handlers.conf

# Auth state: never transferred:
starter/lazysite/auth/users
starter/lazysite/auth/groups

# Generated at build time:
dist/lazysite-*.tar.gz
dist/lazysite-*.tar.gz.sha256
release-manifest.json
sbom.json

# Cache and logs if present in sandbox:
starter/lazysite/cache/
starter/lazysite/logs/

# Version control
.git/
